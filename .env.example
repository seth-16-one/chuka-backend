PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8081
APP_BASE_URL=http://localhost:3000

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
